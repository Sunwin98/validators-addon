{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "heaver:heaver_san1_tc1e",
      "materials": {
        "default": "armor"
      },
      "textures": {
        "default": "textures/skin/heaver_san1_tc1e"
      },
      "geometry": {
        "default": "geometry.san1_566d"
      },
      "scripts": {
        "initialize": [
          "variable.chest_bounce=0;",
          "variable.chest_velocity=0;",
          "variable.vertical_speed=0;",
          "variable.sneak_change=0;",
          "variable.was_sneaking=0;"
        ],
        "pre_animation": [
          "variable.vertical_speed=query.vertical_speed;",
          "variable.sneak_change=math.abs(variable.was_sneaking-query.is_sneaking)*2;",
          "variable.was_sneaking=query.is_sneaking;",
          "variable.chest_velocity=(variable.chest_velocity-(math.clamp(variable.vertical_speed*2,-2.5,2.5)*0.05)-(variable.chest_bounce*0.05))*0.95;",
          "variable.chest_bounce=variable.chest_bounce+variable.chest_velocity+(query.is_moving*1.0)+(variable.sneak_change*2.0);"
        ],
        "animate": [
          "bobbs_chest"
        ]
      },
      "animations": {
        "bobbs_chest": "animation.bobbs.chest_physics"
      },
      "render_controllers": [
        "controller.render.armor"
      ]
    }
  }
}